# Hand-Me-Up environment variables
#
# Copy this file to `.env` and fill in any values you want.
#   cp .env.example .env
#
# The app runs fully WITHOUT any of these — the garment grader falls back to a
# built-in mock when no key is set, so you can clone, install, and run with no
# secrets at all. Set the key only if you want real Claude Vision grading.

# Optional: Anthropic API key for real photo grading (Claude Vision).
# Get one at https://console.anthropic.com/ . Leave blank to use the mock grader.
# Note: EXPO_PUBLIC_* vars are inlined into the app bundle at build time, so this
# is fine for local/demo use only — never ship a production app with a key here.
EXPO_PUBLIC_CLAUDE_API_KEY=
